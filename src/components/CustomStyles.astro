---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
:root {
  --aw-color-bg-page: #ffffff;
  --aw-color-text-default: #121212;
  --aw-color-text-heading: #000000;
  --aw-color-text-muted: rgba(60, 60, 60, 0.6);

  --aw-color-primary: #10b981; /* emerald */
  --aw-color-secondary: #5e3dbb;
  --aw-color-accent: #7b61ff;

  --aw-color-border: rgba(0, 0, 0, 0.1);
  --aw-color-surface: #f7f7f7;
      ::selection {
        background-color: lavender;
      }
}

.dark {
  --aw-color-bg-page: #0a0a0a;
  --aw-color-text-default: #e0e0e0;
  --aw-color-text-heading: #ffffff;
  --aw-color-text-muted: rgba(200, 200, 200, 0.4);

  --aw-color-primary: #10b981; /* emerald */
  --aw-color-secondary: #5e3dbb;
  --aw-color-accent: #a78bfa;

    ::selection {
      background-color: black;
      color: snow;
    }
    }
 
</style>
